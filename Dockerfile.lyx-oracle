FROM node:24-bookworm-slim

WORKDIR /workspace
RUN apt-get update \
  && apt-get install -y --no-install-recommends \
    lyx \
    poppler-utils \
    texlive-latex-base \
    texlive-latex-recommended \
    texlive-latex-extra \
    texlive-fonts-recommended \
  && rm -rf /var/lib/apt/lists/*

ENV NEXT_TELEMETRY_DISABLED=1
ENV IK_RUN_REAL_LYX_ORACLE=1
